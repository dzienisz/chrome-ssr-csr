# Database (Vercel Postgres / Neon) — copy values from the Vercel dashboard,
# or run `vercel env pull .env.local` in a linked project
POSTGRES_URL="postgres://..."
POSTGRES_PRISMA_URL="postgres://..."
POSTGRES_URL_NON_POOLING="postgres://..."
POSTGRES_USER="..."
POSTGRES_HOST="..."
POSTGRES_PASSWORD="..."
POSTGRES_DATABASE="..."

# Optional: API key for /api/analyze authentication (CORS is the primary guard;
# only verified when set — see lib/auth.ts)
# API_SECRET_KEY="your-super-secret-key-here-change-this"
