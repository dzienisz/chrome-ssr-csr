{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "3.10.0",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "permissions": ["activeTab", "scripting", "storage", "notifications"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/probe.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
